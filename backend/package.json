{
  "name": "annhien-backend",
  "version": "1.0.0",
  "description": "API Server cho An Nhien",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "npm run build && node --test test/unit.test.cjs test/api-smoke.test.cjs test/contract-security.test.cjs",
    "test:unit": "npm run build && node --test test/unit.test.cjs",
    "test:api": "npm run build && node --test test/api-smoke.test.cjs",
    "test:contract": "npm run build && node --test test/contract-security.test.cjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "@supabase/supabase-js": "^2.43.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
